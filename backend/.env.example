# Required — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-secret-key-here

# Supabase PostgreSQL connection string — get from Supabase dashboard:
# Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Supabase Storage — get from Supabase dashboard: Settings > API
# SUPABASE_URL is the project URL (e.g. https://xyz.supabase.co)
# SUPABASE_SERVICE_KEY is the service_role key (keep secret — never expose to frontend)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Optional — comma-separated list of allowed CORS origins for the frontend.
# Defaults to http://localhost:3000. Set to your real frontend URL(s) in
# production; never use "*".
FRONTEND_ORIGIN=http://localhost:3000

# Optional — comma-separated IPs/CIDRs of reverse proxies whose x-forwarded-proto
# header the WebSocket TLS gate should trust (SEC-004/SEC-029). Leave empty when
# there is no TLS-terminating proxy in front: the gate then trusts only a native
# wss handshake or a non-public peer. Set it to the proxy's address when one
# terminates TLS — the Pi deployment runs cloudflared on loopback, so:
# TRUSTED_PROXY_IPS=127.0.0.1

# Optional: set to 0 to skip create_all at boot (M146). The live DB schema is
# managed by the manual scripts/ migrations; boot DDL only creates missing
# tables on fresh databases and tolerates the concurrent-boot race either way.
# RUN_STARTUP_DDL=1
